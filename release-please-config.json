{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": true,
  "separate-pull-requests": true,
  "packages": {
    "continuous-learning": {
      "package-name": "continuous-learning",
      "changelog-path": "CHANGELOG.md",
      "initial-version": "0.1.0",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "redis-memory-mcp": {
      "package-name": "redis-memory-mcp",
      "changelog-path": "CHANGELOG.md",
      "initial-version": "0.5.0",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "server/pyproject.toml",
          "jsonpath": "$.project.version"
        }
      ]
    },
    "tech-radar": {
      "package-name": "tech-radar",
      "changelog-path": "CHANGELOG.md",
      "initial-version": "0.4.0",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}